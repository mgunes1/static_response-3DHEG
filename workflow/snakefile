import numpy as np
import sys, os
sys.path.insert(0, workflow.basedir)
sys.path.insert(0, os.path.join(workflow.basedir, '..'))
from qharv.cross.snake import run_cmd
from utils.physics import get_alpha, q_over_kf as _q_over_kf

import json as _json

def _alpha_str(rs, nelec, qidx):
    return '%.3f' % get_alpha(_q_over_kf(rs, nelec, qidx), float(rs))

apath = 'runs/rs{rs}-n{nelec}/qv{qx}_{qy}_{qz}-vq{vq}/{func}-e{epre}-qa{alpha}'
fscf_inp = '%s/scf/scf.inp' % apath
fscf_out = fscf_inp[:-4]+'.out'
feinspline = '%s/scf/eshdf.h5' % apath
fopt_inp = '%s/opt-sj/opt.xml' % apath
fopt_out = fopt_inp[:-4]+'.out'
fbopt_inp = '%s/opt-sjb/opt.xml' % apath
fbopt_out = fbopt_inp[:-4]+'.out'

# Forbid wildcards from swallowing path separators
# wildcard_constraints:
rs    = r"[0-9.]+",
nelec = r"[0-9]+",
qx    = r"-?[0-9]+",
qy    = r"-?[0-9]+",
qz    = r"-?[0-9]+",
vq    = r"[0-9.]+",
func  = r"[a-zA-Z0-9]+",
epre  = r"[0-9.]+",
alpha = r"[0-9.]+",
wf    = r"[a-z]+",
tproj = r"[0-9.]+",
ts    = r"[0-9.]+",
nwtot = r"[0-9]+",

subdir = 't{tproj}-ts{ts}-nw{nwtot}'
fdmc_inp = '%s/{wf}-%s/dmc.xml' % (apath, subdir)
fdmc_out = fdmc_inp[:-4]+'.out'
fdmc_csv = fdmc_inp[:-4]+'.csv'

point_done_flag = ('runs/rs{rs}-n{nelec}/qv{qx}_{qy}_{qz}-vq{vq}/'
                   '{func}-e{epre}-{wf}-t{tproj}-ts{ts}-nw{nwtot}.point_done')

def gen_qidx(mq):
    ql = []
    for qx in range(mq):
        for qy in range(qx+1):
            for qz in range(qy+1):
                ql.append([qx, qy, qz])
    ql.sort(key=lambda q: q[0]**2 + q[1]**2 + q[2]**2)
    return ql[1:]


funcs = ['ni']
vq_max = { 2: 0.02000,
           5: 0.01200,
          10: 0.00400,
          15: 0.00100,
          20: 0.00100,
          30: 0.00060,
          50: 0.00050,
          60: 0.00040
          }

nelec = 14
rsl = [2]
vql = [0.02]

qidxl = [[1,0,0]]#gen_qidx(5)[::5]

wf = 'sj'
tpmult = 15.625
nwalker = 1024

rsl = ['%.1f' % rs for rs in rsl]
vql = ['%.5f' % vq for vq in vql]

# --- Targets ---
targets = []

t1 = expand(point_done_flag, allow_missing=True,
  wf=wf, nelec=nelec, vq=vql, func=funcs, epre=125
)
for qidx in qidxl:
  t2 = expand(t1, allow_missing=True,
    qx=qidx[0], qy=qidx[1], qz=qidx[2]
  )
  for rs in rsl:
    rs = float(rs)
    ts = rs/(12*nelec**0.5) if wf == 'sjb' else rs/20
    tproj = tpmult*nelec*rs
    qmc_kws = dict(
      wf = wf,
      tproj = tproj,
      ts = '%.4f' % ts,
      nwtot = nwalker,
    )
    t3 = expand(t2, allow_missing=False, rs=rs, **qmc_kws)
    targets += t3

nk2 = 6
nproc = 96
cmds = dict(
  pw = 'unset SLURM_JOBID; source /mnt/home/mgunes/software/q-e/dev.sh; mpirun -np %d pw.x -nb %d -in' % (nk2, nk2),
  p2q = 'unset SLURM_JOBID; source /mnt/home/mgunes/software/qmcpack/env.sh; mpirun -n 1 convertpw4qmc',
  dmc = ' source /mnt/home/mgunes/software/qmcpack/env.sh; mpirun -np %d qmcpack_complex' % nproc,
)

localrules: write_scf, run_scf, convertpw, write_opt, write_dmc, sdat, point_done, collect_data

collect_targets = expand(
  'pp/output_new/E_all_rs{rs}-n{nelec}.npz', rs=rsl, nelec=[nelec])

rule all:
  input: collect_targets

def _scf_cmd(output, wildcards):
    vq = float(wildcards.vq) * float(wildcards.alpha)
    cmd  = 'python3 workflow/wcospot.py -o %s' % output[0]
    cmd += ' --rs %f --nelec %d' % (float(wildcards.rs), int(wildcards.nelec))
    cmd += ' --func %s -epre %f' % (wildcards.func, float(wildcards.epre))
    cmd += ' --vq %f --qx %d --qy %d --qz %d' % (
        2*vq, int(wildcards.qx), int(wildcards.qy), int(wildcards.qz))
    return cmd

def _opt_cmd(input, output, wildcards):
    cmd  = 'python3 workflow/wdmc.py %s' % input[0]
    cmd += ' -i %s -o %s' % (input[1], output[0])
    cmd += ' --nopt 12 --no_moire --vcospot %f' % float(wildcards.vq)
    return cmd

rule write_scf:
  output: fscf_inp
  run: shell(_scf_cmd(output, wildcards))

rule run_scf:
  threads: 6
  input: ancient('{path}/{pre}scf.inp')
  output:
    out = '{path}/{pre}scf.out'
  run:
    cmd = run_cmd(cmds['pw'], input[0])
    shell(cmd)

rule convertpw:
  input: fscf_inp, fscf_out
  output: feinspline
  run:
    import os
    from qharv.cross import pwscf
    CMD = cmds['p2q']
    finp = input[0]
    dsave = pwscf.find_save(finp)
    fxml = os.path.join(dsave, 'data-file-schema.xml')
    cmd = '%s %s -o %s' % (CMD, fxml, output[0])
    shell(cmd)

rule write_opt:
  input: feinspline, fscf_inp
  output: fopt_inp
  run: shell(_opt_cmd(input, output, wildcards))

rule write_bopt:
  input: fopt_inp, fopt_out
  output: fbopt_inp
  run:
    fopt_out = input[0]
    fopt_inp = fopt_out.replace(".out", ".xml")
    fout = output[0]
    ts_frac = 0.1
    cmd = 'python3 workflow/bopt.py -o %s -i %s --ts_frac %f' % (
      fout, fopt_inp, ts_frac)
    cmd += ' --nsample %d' % (576*1024)
    shell(cmd)

rule write_dmc:
  input: '{path}/opt-{wf}/opt.xml', '{path}/opt-{wf}/opt.out'
  output: '{path}/{wf}-%s/dmc.xml' % subdir
  run:
    tproj = float(wildcards.tproj)
    ts = float(wildcards.ts)
    nw = int(wildcards.nwtot)
    cmd = "python3 workflow/o2dmc.py -o %s -i %s" % (output[0], input[0])
    cmd += " --nwalker %d --timestep %f --tproj %f" % (nw, ts, tproj)
    if wildcards.wf == 'sjb':
      cmd += ' -w'
    shell(cmd)

rule run_qmc:
  input: '{path}/{prefix}.xml'
  output: '{path}/{prefix}.out'
  run:
    if wildcards.prefix not in ['vmc', 'opt', 'dmc']:
      msg = 'wrong rule for %s' % input[0]
      raise RuntimeError(msg)
    cmd = run_cmd(cmds['dmc'], input[0])
    shell(cmd)

rule sdat:
  input: fdmc_inp, fdmc_out
  output: fdmc_csv
  run:
    wf = wildcards.wf
    if wf == 'sj':
      neql = [16, 64, 32]
    elif wf == 'sjb':
      neql = [64, 32, 256, 128]
    cmd = 'python3 workflow/energy.py'
    cmd += ' -i %s -o %s' % (input[0], output[0])
    for neq in neql:
      cmd += ' -e %d' % neq
    shell(cmd)

# ============================================================
# Phase 4 — production target (alpha from get_alpha)
# ============================================================

def _production_input(wildcards):
    alpha_str = _alpha_str(
        wildcards.rs, wildcards.nelec,
        [int(wildcards.qx), int(wildcards.qy), int(wildcards.qz)])
    return [fdmc_csv.format(
        rs=wildcards.rs, nelec=wildcards.nelec,
        qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
        vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre,
        alpha=alpha_str, wf=wildcards.wf,
        tproj=wildcards.tproj, ts=wildcards.ts, nwtot=wildcards.nwtot)]

rule point_done:
  input: _production_input
  output: touch(point_done_flag)

# ============================================================
# Final rule: collect all data and write report
# ============================================================

def _collect_inputs(wildcards):
    pat = 'rs%s-n%s' % ('%.1f' % float(wildcards.rs), str(int(wildcards.nelec)))
    return [t for t in targets if pat in t]

rule collect_data:
  input: _collect_inputs
  output:
    data   = 'pp/output_new/E_all_rs{rs}-n{nelec}.npz',
    report = 'pp/output_new/report_rs{rs}-n{nelec}.json',
  run:
    import glob as _glob, subprocess
    from utils.io_utils import collect_and_save, _parse_dmc_xml

    rs_f     = float(wildcards.rs)
    Ne_i     = int(wildcards.nelec)
    rs_n_dir = 'runs/rs%s-n%s' % (wildcards.rs, wildcards.nelec)

    os.makedirs('pp/output_new', exist_ok=True)

    collect_and_save(
      rs_n_dir=rs_n_dir, rs=rs_f, Ne=Ne_i,
      qidxl=qidxl, vql=[float(v) for v in vql],
      func=funcs[0], ecut_pre=125, wf=wf,
      tpmult=tpmult, nwalker=nwalker,
      outpath=output.data,
    )

    dmc_xmls = _glob.glob(rs_n_dir + '/**/dmc.xml', recursive=True)
    qmc_info, jastrow_info = {}, {}
    if dmc_xmls:
      qmc_info, jastrow_info = _parse_dmc_xml(dmc_xmls[0])

    try:
      git_hash = subprocess.check_output(
        ['git', 'rev-parse', 'HEAD'], cwd=workflow.basedir
      ).decode().strip()
    except Exception:
      git_hash = 'unknown'

    report = dict(
      rs=rs_f, Ne=Ne_i,
      qidx_list=[list(q) for q in qidxl],
      vq_list=[float(v) for v in vql],
      dft_func=funcs[0],
      tpmult=tpmult,
      nwalker=nwalker,
      ecut_pre=125,
      wf=wf,
      git_hash=git_hash,
      qmc_block=qmc_info,
      jastrow_block=jastrow_info,
    )
    with open(output.report, 'w') as f:
      _json.dump(report, f, indent=2)

