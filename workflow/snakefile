# ============================================================
# Phase 3 — alpha_select checkpoint chain
#
# Each iteration n in [0, MAX_ALPHA_ITER] produces a JSON
# {func}-e{epre}-alpha_iter{n}.json. The iteration n=0 evaluates the
# initial grid; iteration n>0 evaluates the next_alphas requested by
# iteration n-1's rescan. After each iteration the JSON is interpreted by
# finalize_alpha which walks iter0..N looking for the first one with status
# in {ok, failed} and copies it to alpha_selected.json.
# ============================================================

import json as _json

def _alphas_for_iter(wildcards):
    """Return the list of alpha strings to evaluate at this iteration."""
    if float(wildcards.vq) == 0.0:
        return []   # vq=0: no scan needed; select_alpha returns alpha_opt=0 directly
    n = int(wildcards.iteration)
    if n == 0:
        return alpha_grid_for(wildcards.rs, wildcards.nelec,
                              [int(wildcards.qx), int(wildcards.qy),
                               int(wildcards.qz)])
    prev = alpha_iter_json.format(
        rs=wildcards.rs, nelec=wildcards.nelec,
        qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
        vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre,
        iteration=n - 1,
    )
    if not os.path.exists(prev):
        return []
    with open(prev) as f:
        data = _json.load(f)
    return list(data.get('next_alphas', []))

def _scan_outs_for_iter(wildcards):
    """Snakemake input function: opt.out paths for this iteration's alphas."""
    alphas = _alphas_for_iter(wildcards)
    return [fscan_opt_out.format(
        rs=wildcards.rs, nelec=wildcards.nelec,
        qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
        vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre,
        alpha=a) for a in alphas]

def _prev_iter_input(wildcards):
    n = int(wildcards.iteration)
    if n == 0:
        return []
    return [alpha_iter_json.format(
        rs=wildcards.rs, nelec=wildcards.nelec,
        qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
        vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre,
        iteration=n - 1)]

checkpoint alpha_select:
  input:
    scan = _scan_outs_for_iter,
    prev = _prev_iter_input,
  output: alpha_iter_json
  wildcard_constraints:
    iteration = r"[0-9]+",
  run:
    n = int(wildcards.iteration)
    new_alphas = _alphas_for_iter(wildcards)
    new_E = [alpha_scan.load_vmc_energy(p) for p in input.scan]

    if n == 0:
      cum_alphas = list(new_alphas)
      cum_E = list(new_E)
      halfwidth = SCAN_HALFWIDTH_INIT
    else:
      with open(input.prev[0]) as f:
        pj = _json.load(f)
      cum_alphas = [str(a) for a in pj['alpha_grid']] + list(new_alphas)
      cum_E = [(e, de) for e, de in zip(pj['E_grid'], pj['dE_grid'])] + list(new_E)
      halfwidth = float(pj['halfwidth'])   # rescan_widen removed; only rescan_shift possible

    sel = alpha_scan.select_alpha(
      rs=float(wildcards.rs),
      nelec=int(wildcards.nelec),
      qidx=[int(wildcards.qx), int(wildcards.qy), int(wildcards.qz)],
      vq=float(wildcards.vq),
      alpha_grid=cum_alphas,
      energies=cum_E,
      iteration=n,
      halfwidth=halfwidth,
      max_iterations=MAX_ALPHA_ITER + 1,
    )
    os.makedirs(os.path.dirname(output[0]), exist_ok=True)
    with open(output[0], 'w') as f:
      f.write(sel.to_json())

def _finalize_alpha_input(wildcards):
    """Walk iter0..MAX_ALPHA_ITER and return the JSON of the first iteration
    whose status is not a rescan. Forces upstream checkpoint runs as needed."""
    last_path = None
    for n in range(MAX_ALPHA_ITER + 1):
      ck = checkpoints.alpha_select.get(
        rs=wildcards.rs, nelec=wildcards.nelec,
        qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
        vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre,
        iteration=str(n))
      last_path = ck.output[0]
      with open(last_path) as f:
        data = _json.load(f)
      if data['status'] not in ('rescan_shift',):
        return [last_path]
    return [last_path]

checkpoint finalize_alpha:
  input: _finalize_alpha_input
  output: alpha_selected_json
  run:
    import shutil
    shutil.copyfile(input[0], output[0])

# ============================================================
# Phase 4 — production target driven by alpha_selected.json
# ============================================================

# Per-point sentinel marks the production work done. Its input function
# resolves the alpha picked by the alpha_select chain and routes either to
# the production DMC csv (status=ok) or alpha_selected.json (status=failed
# → DMC skipped for this point).

def _production_input(wildcards):
    ck = checkpoints.finalize_alpha.get(
      rs=wildcards.rs, nelec=wildcards.nelec,
      qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
      vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre)
    fjson = ck.output[0]
    with open(fjson) as f:
      data = _json.load(f)
    if data['status'] != 'ok' or data.get('alpha_opt') is None:
      # Alpha scan failed — skip DMC entirely. The failed report (written by
      # aggregate_alpha_manifest) will list the scan data for manual fixing.
      return [fjson]
    alpha_str = '%.3f' % float(data['alpha_opt'])
    # HACK !!!!!!! fdmc_csv  --> fdmc_inp
    return [fjson, fdmc_inp.format(
      rs=wildcards.rs, nelec=wildcards.nelec,
      qx=wildcards.qx, qy=wildcards.qy, qz=wildcards.qz,
      vq=wildcards.vq, func=wildcards.func, epre=wildcards.epre,
      alpha=alpha_str, wf=wildcards.wf,
      tproj=wildcards.tproj, ts=wildcards.ts, nwtot=wildcards.nwtot)]

rule point_done:
  input: _production_input
  output: touch(point_done_flag)
  # All work happens via the inputs; output is a touched flag.

# ============================================================
# Phase 5 — alpha manifest aggregation
# Consolidates per-(rs, Ne, q, vq) alpha_selected.json files into one
# manifest the post-processing can read directly.
# ============================================================

def _manifest_inputs(wildcards):
    rs_str = wildcards.rs
    nelec_i = int(wildcards.nelec)
    out = []
    for qidx in qidxl:
      for vqs in vql:
        for func in funcs:
          ck = checkpoints.finalize_alpha.get(
            rs=rs_str, nelec=nelec_i,
            qx=qidx[0], qy=qidx[1], qz=qidx[2],
            vq=vqs, func=func, epre='125')
          out.append(ck.output[0])
    return out

rule aggregate_alpha_manifest:
  input: _manifest_inputs
  output:
    manifest = alpha_manifest_json,
    failed   = alpha_failed_report,
  run:
    manifest = {
      'rs': float(wildcards.rs),
      'nelec': int(wildcards.nelec),
      'entries': {},
    }
    failed_entries = []
    for fjson in input:
      with open(fjson) as f:
        d = _json.load(f)
      qx, qy, qz = d['qidx']
      key = '%d_%d_%d/%s' % (qx, qy, qz, ('%.5f' % float(d['vq'])))
      manifest['entries'][key] = {
        'alpha_opt': d.get('alpha_opt'),
        'status': d['status'],
        'reason': d.get('reason', ''),
        'iteration': d.get('iteration'),
        'curvature_a': d.get('curvature_a'),
        'snr': d.get('snr'),
        'chi2_red': d.get('chi2_red'),
      }
      if d['status'] != 'ok':
        failed_entries.append({
          'q': [qx, qy, qz],
          'vq': float(d['vq']),
          'status': d['status'],
          'reason': d.get('reason', ''),
          'snr': d.get('snr'),
          'chi2_red': d.get('chi2_red'),
          'alpha_grid': d.get('alpha_grid', []),
          'E_grid':     d.get('E_grid', []),
          'dE_grid':    d.get('dE_grid', []),
        })
    with open(output.manifest, 'w') as f:
      _json.dump(manifest, f, indent=2)
    with open(output.failed, 'w') as f:
      _json.dump({
        'rs': float(wildcards.rs), 'nelec': int(wildcards.nelec),
        'n_failed': len(failed_entries),
        'note': 'DMC was skipped for these points. Fix alpha by hand and rerun.',
        'failed': failed_entries,
      }, f, indent=2)
