  pw = 'unset SLURM_JOBID; source /mnt/home/mgunes/software/q-e/dev.sh; mpirun -np %d pw.x -nb %d -in' % (nk2, nk2),
  p2q = 'unset SLURM_JOBID; source /mnt/home/mgunes/software/qmcpack/env.sh; mpirun -n 1 convertpw4qmc',
  dmc = ' source /mnt/home/mgunes/software/qmcpack/env.sh; mpirun -np %d qmcpack_complex' % nproc,
)

localrules: write_scf, run_scf, convertpw, write_opt, write_dmc, sdat, write_scf_scan, convertpw_scan, write_opt_scan, alpha_select, finalize_alpha, point_done, aggregate_alpha_manifest, write_params_report

manifest_targets = expand(alpha_manifest_json, rs=rsl, nelec=nelec)
params_targets = expand('runs/rs{rs}-n{nelec}/params.json', rs=rsl, nelec=[nelec])

rule all:
  input: targets + manifest_targets + params_targets

rule write_params_report:
  output: 'runs/rs{rs}-n{nelec}/params.json'
  run:
    import json, subprocess
    try:
      git_hash = subprocess.check_output(
        ['git', 'rev-parse', 'HEAD'], cwd=workflow.basedir
      ).decode().strip()
    except Exception:
      git_hash = 'unknown'
    params = dict(
      rs=wildcards.rs, nelec=wildcards.nelec,
      vql=vql, qidxl=[list(q) for q in qidxl],
      wf=wf, nwalker=nwalker, tpmult=tpmult, funcs=funcs,
      git_hash=git_hash,
    )
    os.makedirs(os.path.dirname(output[0]), exist_ok=True)
    with open(output[0], 'w') as f:
      json.dump(params, f, indent=2)

def _scf_cmd(output, wildcards):
    vq = float(wildcards.vq) * float(wildcards.alpha)
    cmd  = 'python3 workflow/wcospot.py -o %s' % output[0]
    cmd += ' --rs %f --nelec %d' % (float(wildcards.rs), int(wildcards.nelec))
    cmd += ' --func %s -epre %f' % (wildcards.func, float(wildcards.epre))
    cmd += ' --vq %f --qx %d --qy %d --qz %d' % (
        2*vq, int(wildcards.qx), int(wildcards.qy), int(wildcards.qz))
    return cmd

def _opt_cmd(input, output, wildcards):
    cmd  = 'python3 workflow/wdmc.py %s' % input[0]
    cmd += ' -i %s -o %s' % (input[1], output[0])
    cmd += ' --nopt 12 --no_moire --vcospot %f' % float(wildcards.vq)
    return cmd

rule write_scf:
  output: fscf_inp
  run: shell(_scf_cmd(output, wildcards))

rule run_scf:
  threads: 6
  input: ancient('{path}/{pre}scf.inp')
  output:
    out = '{path}/{pre}scf.out'
    #done = '{path}/{pre}.scf_done'
  run:
    cmd = run_cmd(cmds['pw'], input[0])
    shell(cmd)
    #shell(r"""
    #  set -e
    #  {cmd}
    #  grep -q "JOB DONE\." {output.out}
    #  touch {output.done}
    #""")

rule convertpw:
  input: fscf_inp, fscf_out
  output: feinspline
  run:
    import os
    from qharv.cross import pwscf
    CMD = cmds['p2q']
    finp = input[0]
    dsave = pwscf.find_save(finp)
    fxml = os.path.join(dsave, 'data-file-schema.xml')
    cmd = '%s %s -o %s' % (CMD, fxml, output[0])
    shell(cmd)

rule write_opt:
  input: feinspline, fscf_inp
  output: fopt_inp
  run: shell(_opt_cmd(input, output, wildcards))

rule write_bopt:
  input: fopt_inp, fopt_out
  output: fbopt_inp
  run:
    fopt_out = input[0]
    fopt_inp = fopt_out.replace(".out", ".xml")
    fout = output[0]
    ts_frac = 0.1
    cmd = 'python3 workflow/bopt.py -o %s -i %s --ts_frac %f' % (
      fout, fopt_inp, ts_frac)
    # need lots of samples to properly optimize the backflow
    cmd += ' --nsample %d' % (576*1024)
    shell(cmd)

rule write_dmc:
  input: '{path}/opt-{wf}/opt.xml', '{path}/opt-{wf}/opt.out'
  output: '{path}/{wf}-%s/dmc.xml' % subdir
  run:
    tproj = float(wildcards.tproj)
    ts = float(wildcards.ts)
    nw = int(wildcards.nwtot)
    cmd = "python3 workflow/o2dmc.py -o %s -i %s" % (output[0], input[0])
    cmd += " --nwalker %d --timestep %f --tproj %f" % (nw, ts, tproj)
    #cmd += ' --checkpoint 99'
    if wildcards.wf == 'sjb':
      cmd += ' -w'  # add warmup VMC
    shell(cmd)

rule run_qmc:
  input: '{path}/{prefix}.xml'
  output: '{path}/{prefix}.out'
  run:
    if wildcards.prefix not in ['vmc', 'opt', 'dmc']:
      msg = 'wrong rule for %s' % input[0]
      raise RuntimeError(msg)
    cmd = run_cmd(cmds['dmc'], input[0])
    shell(cmd)

rule sdat:
  input: fdmc_inp, fdmc_out
  output: fdmc_csv
  run:
    wf = wildcards.wf
    if wf == 'sj':
      neql = [16, 64, 32]
    elif wf == 'sjb':
      neql = [64, 32, 256, 128]
    cmd = 'python3 workflow/energy.py'
    cmd += ' -i %s -o %s' % (input[0], output[0])
    for neq in neql:
      cmd += ' -e %d' % neq
    shell(cmd)

