# Forbid wildcards from swallowing path separators (otherwise {vq} can match
# '0.00000/scan' and the scan-vs-production rule split becomes ambiguous).
wildcard_constraints:
    rs    = r"[0-9.]+",
    nelec = r"[0-9]+",
    qx    = r"-?[0-9]+",
    qy    = r"-?[0-9]+",
    qz    = r"-?[0-9]+",
    vq    = r"[0-9.]+",
    func  = r"[a-zA-Z0-9]+",
    epre  = r"[0-9.]+",
    alpha = r"[0-9.]+",
    wf    = r"[a-z]+",
    tproj = r"[0-9.]+",
    ts    = r"[0-9.]+",
    nwtot = r"[0-9]+",

subdir = 't{tproj}-ts{ts}-nw{nwtot}'
fdmc_inp = '%s/{wf}-%s/dmc.xml' % (apath, subdir)
fdmc_out = fdmc_inp[:-4]+'.out'
fdmc_csv = fdmc_inp[:-4]+'.csv'

# Production target is the point_done flag (resolved via the
# alpha_select / finalize_alpha checkpoint chain).

def gen_qidx(mq):
    ql = []
    for qx in range(mq):
        for qy in range(qx+1):
            for qz in range(qy+1):
                ql.append([qx, qy, qz])

    ql.sort(key=lambda q: q[0]**2 + q[1]**2 + q[2]**2)
    return ql[1:]


funcs = ['ni']
vq_max = { 2: 0.02000,
           5: 0.01200,
          10: 0.00400,
          15: 0.00100,
          20: 0.00100,
          30: 0.00060,
          50: 0.00050,
          60: 0.00040
          }

nelec = 162
rsl = [80]
vql =[0.0004]#np.arange(0,0.0025,0.0005)  # [0.000,...,0.002]; vq=0 used as E0 referencei

qidxl = gen_qidx(5)[::5]

wf = 'sj'
tpmult = 15.625
nwalker = 1024

rsl = ['%.1f' % rs for rs in rsl]
vql = ['%.5f' % vq for vq in vql]


# --- Initial alpha scan grid: wide uniform [0.05, 1.50], no centering ---
# alpha_opt shifts with vq so a fixed-center grid misses the minimum at
# large vq. All vq at a given (rs, Ne, q) use the same grid.
SCAN_HALFWIDTH_INIT = 0.25   # kept for rescan_shift only
SCAN_NPOINTS_INIT = 10
MAX_ALPHA_ITER = 3
_alpha_grid_cache = {}

def alpha_grid_for(rs, nelec, qidx):
    key = (float(rs), int(nelec), tuple(qidx))
    guess_alpha = guess_alpha0 if float(rs) <= 5 else guess_alpha1 if float(rs) < 21 else guess_alpha2
    if key not in _alpha_grid_cache:
        _alpha_grid_cache[key] = alpha_scan.make_alpha_grid_uniform(
            n=SCAN_NPOINTS_INIT,
            hi=min(guess_alpha(float(rs), int(nelec), list(qidx)) * 2 , 1.5),
        )
    return _alpha_grid_cache[key]

# Per-iteration JSON path written by checkpoint alpha_select.
alpha_iter_json = ('runs/rs{rs}-n{nelec}/qv{qx}_{qy}_{qz}-vq{vq}/'
                   '{func}-e{epre}-alpha_iter{iteration}.json')
alpha_selected_json = ('runs/rs{rs}-n{nelec}/qv{qx}_{qy}_{qz}-vq{vq}/'
                       '{func}-e{epre}-alpha_selected.json')
point_done_flag = ('runs/rs{rs}-n{nelec}/qv{qx}_{qy}_{qz}-vq{vq}/'
                   '{func}-e{epre}-{wf}-t{tproj}-ts{ts}-nw{nwtot}.point_done')
alpha_manifest_json = 'runs/alpha_manifest_rs{rs}-n{nelec}.json'
alpha_failed_report  = 'runs/alpha_failed_report_rs{rs}-n{nelec}.json'

# --- Targets ---
# Phase 3: target = alpha_selected.json per (rs, Ne, q, vq).
# Phase 4 will replace this with the production DMC csv resolved through
# the checkpoint.
targets = []                  # production point_done flags (Phase 4)
targets_alpha = []            # alpha_selected.json files (Phase 3, kept for debug)

t1 = expand(point_done_flag, allow_missing=True,
  wf=wf, nelec=nelec, vq=vql, func=funcs, epre=125
)
ta1 = expand(alpha_selected_json, allow_missing=True,
  nelec=nelec, vq=vql, func=funcs, epre=125
)
for qidx in qidxl:
  t2 = expand(t1, allow_missing=True,
    qx=qidx[0], qy=qidx[1], qz=qidx[2]
  )
  ta2 = expand(ta1, allow_missing=True,
    qx=qidx[0], qy=qidx[1], qz=qidx[2]
  )
  for rs in rsl:
    rs = float(rs)
    ts = rs/(12*nelec**0.5) if wf == 'sjb' else rs/20
    tproj = tpmult*nelec*rs
    qmc_kws = dict(
      wf = wf,
      tproj = tproj,
      ts = '%.4f' % ts,
      nwtot = nwalker,
    )
    t3 = expand(t2, allow_missing=False, rs=rs, **qmc_kws)
    targets += t3

    ta3 = expand(ta2, allow_missing=False, rs=rs)
    targets_alpha += ta3

